{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "or-wiki-astro",
  "pages_build_output_dir" : "./dist",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  //For Workers
  //"main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ]/*,
  //For Workers
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }*/
}
